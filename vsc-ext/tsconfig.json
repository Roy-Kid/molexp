{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "jsx": "react-jsx",
    "strict": true,
    "noEmit": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "types": ["node", "vscode", "react", "react-dom"],
    "baseUrl": ".",
    "paths": {
      "@/*": ["../ui/src/*"]
    }
  },
  "include": ["src", "webview"]
}
