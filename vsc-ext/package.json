{
  "name": "molexp-workflow-preview",
  "displayName": "MolExp Workflow Preview",
  "description": "Preview a molexp workflow.json IR as an interactive DAG, reusing the molexp UI workflow components.",
  "version": "0.1.0",
  "publisher": "molcrafts",
  "engines": {
    "vscode": "^1.90.0"
  },
  "categories": ["Visualization", "Other"],
  "main": "./dist/extension.js",
  "activationEvents": [],
  "contributes": {
    "customEditors": [
      {
        "viewType": "molexp.workflowPreview",
        "displayName": "MolExp Workflow Preview",
        "selector": [
          { "filenamePattern": "*workflow.json" }
        ],
        "priority": "option"
      }
    ],
    "commands": [
      {
        "command": "molexp.openWorkflowPreview",
        "title": "MolExp: Open Workflow Preview"
      }
    ]
  },
  "scripts": {
    "build": "node build.mjs",
    "watch": "node build.mjs --watch",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@types/vscode": "^1.90.0"
  }
}
