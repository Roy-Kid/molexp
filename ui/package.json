{
  "name": "molexp-ui",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "rsbuild build && rm -rf ../src/molexp/dist && mkdir -p ../src/molexp/dist && cp -r dist/. ../src/molexp/dist/",
    "dev": "rsbuild dev",
    "dev:mock": "MOLEXP_USE_MOCK=true rsbuild dev",
    "preview": "rsbuild preview",
    "generate:api": "npx openapi-typescript-codegen --input ../openapi.json --output src/api/generated --client fetch",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "typecheck": "tsc --noEmit",
    "test": "rstest run",
    "test:watch": "rstest watch"
  },
  "dependencies": {
    "@molcrafts/molvis-core": "^0.0.5",
    "@monaco-editor/react": "^4.7.0",
    "@radix-ui/react-accordion": "^1.2.12",
    "@radix-ui/react-alert-dialog": "^1.1.15",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-scroll-area": "^1.2.10",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@xyflow/react": "^12.9.3",
    "ajv": "^8.17.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^0.555.0",
    "monaco-editor": "^0.55.1",
    "plotly.js-cartesian-dist-min": "^3.5.0",
    "radix-ui": "^1.4.3",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-markdown": "^10.1.0",
    "react-plotly.js": "^2.6.0",
    "react-resizable-panels": "^3.0.6",
    "react-router-dom": "^7.9.6",
    "remark-gfm": "^4.0.1",
    "tailwind-merge": "^3.4.0",
    "zustand": "^5.0.8"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.11",
    "@rsbuild/core": "^1.6.7",
    "@rsbuild/plugin-react": "^1.4.2",
    "@rstest/adapter-rsbuild": "^0.2.6",
    "@rstest/core": "^0.7.0",
    "@tailwindcss/postcss": "^4.1.17",
    "@types/react": "^19.2.6",
    "@types/react-dom": "^19.2.3",
    "autoprefixer": "^10.4.22",
    "msw": "^2.12.3",
    "openapi-typescript-codegen": "^0.30.0",
    "postcss": "^8.5.6",
    "tailwindcss": "^4.1.17",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  },
  "msw": {
    "workerDirectory": [
      "public"
    ]
  }
}
