{
    "$schema": "http://json-schema.org/draft-07/schema#",
    "$id": "https://molexp.io/schemas/project.json",
    "title": "Project",
    "description": "Top-level organizational unit containing experiments",
    "type": "object",
    "properties": {
        "id": {
            "type": "string",
            "description": "Unique project identifier"
        },
        "name": {
            "type": "string",
            "description": "Project name"
        },
        "description": {
            "type": [
                "string",
                "null"
            ],
            "description": "Project description"
        },
        "created_at": {
            "type": "string",
            "format": "date-time",
            "description": "Creation timestamp"
        },
        "updated_at": {
            "type": "string",
            "format": "date-time",
            "description": "Last update timestamp"
        }
    },
    "required": [
        "id",
        "name",
        "created_at",
        "updated_at"
    ],
    "additionalProperties": false
}
