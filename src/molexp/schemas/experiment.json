{
    "$schema": "http://json-schema.org/draft-07/schema#",
    "$id": "https://molexp.io/schemas/experiment.json",
    "title": "Experiment",
    "description": "Collection of related runs within a project",
    "type": "object",
    "properties": {
        "id": {
            "type": "string",
            "description": "Unique experiment identifier"
        },
        "project_id": {
            "type": "string",
            "description": "Parent project identifier"
        },
        "name": {
            "type": "string",
            "description": "Experiment name"
        },
        "description": {
            "type": [
                "string",
                "null"
            ],
            "description": "Experiment description"
        },
        "created_at": {
            "type": "string",
            "format": "date-time",
            "description": "Creation timestamp"
        },
        "updated_at": {
            "type": "string",
            "format": "date-time",
            "description": "Last update timestamp"
        }
    },
    "required": [
        "id",
        "project_id",
        "name",
        "created_at",
        "updated_at"
    ],
    "additionalProperties": false
}