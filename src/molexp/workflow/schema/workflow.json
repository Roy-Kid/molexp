{
    "$schema": "http://json-schema.org/draft-07/schema#",
    "$id": "https://molexp.io/schemas/workflow/workflow.json",
    "title": "Workflow",
    "description": "Complete workflow definition containing tasks, links, and metadata",
    "type": "object",
    "properties": {
        "workflow_id": {
            "type": "string",
            "description": "Unique workflow identifier (auto-generated)",
            "pattern": "^workflow_[a-f0-9]{8}$",
            "examples": [
                "workflow_abc12345"
            ]
        },
        "name": {
            "type": [
                "string",
                "null"
            ],
            "description": "Optional workflow name",
            "examples": [
                "my_workflow",
                "production_pipeline",
                null
            ]
        },
        "task_configs": {
            "type": "array",
            "description": "List of task configurations in the workflow",
            "items": {
                "$ref": "task_config.json"
            },
            "default": []
        },
        "links": {
            "type": "array",
            "description": "List of links between tasks defining the workflow graph",
            "items": {
                "$ref": "link.json"
            },
            "default": []
        },
        "metadata": {
            "$ref": "workflow_metadata.json",
            "description": "Optional workflow metadata"
        },
        "workflow_contract": {
            "$ref": "workflow_contract.json",
            "description": "Optional sidecar contract describing typed task I/O, declared artifacts, and static validation checks. Absent in older IR; loaders MUST treat its absence as 'no contract declared'."
        }
    },
    "required": [
        "workflow_id",
        "task_configs",
        "links",
        "metadata"
    ],
    "additionalProperties": false,
    "examples": [
        {
            "workflow_id": "workflow_abc12345",
            "name": "example_workflow",
            "task_configs": [
                {
                    "task_id": "k",
                    "task_type": "core.constant",
                    "config": {
                        "value": 10
                    },
                    "status": "pending"
                },
                {
                    "task_id": "doubled",
                    "task_type": "core.multiply",
                    "config": {
                        "factor": 2
                    },
                    "status": "pending"
                }
            ],
            "links": [
                {
                    "source": "k",
                    "target": "doubled",
                    "mapping": {},
                    "status": "pending"
                }
            ],
            "metadata": {
                "label": "Example Workflow",
                "description": "A simple example workflow",
                "tags": [
                    "example",
                    "demo"
                ],
                "custom": {
                    "owner": "user1"
                }
            }
        }
    ]
}
